<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    /* Styles globaux que Juice va injecter partout */
    body { 
      margin: 0; padding: 0; 
      background-color: #f4f7f9; 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .main-container {
      max-width: 600px;
      margin: 20px auto;
      background: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .header {
      background-color: #0052FF; /* Bleu Foma */
      padding: 30px;
      text-align: center;
    }
    .content {
      padding: 40px;
      color: #333333;
      line-height: 1.6;
    }
    .footer {
      padding: 20px;
      text-align: center;
      font-size: 12px;
      color: #999999;
      background-color: #fafafa;
    }
  </style>
</head>
<body>
  <div class="main-container">
    <div class="header">
      <img src="{{logoUrl}}" alt="Logo" width="120">
    </div>
    
    <div class="content">
      {{{body}}} </div>

    <div class="footer">
      © 2026 {{companyName}}. Envoyé via Foma SE.
    </div>
  </div>
</body>
</html>