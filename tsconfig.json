{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false, 
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0" 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}