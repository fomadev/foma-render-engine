{
  "name": "foma-render-engine",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup src/index.ts --watch --format esm,cjs",
    "build": "tsup src/index.ts --format esm,cjs --dts --minify",
    "test": "vitest",
    "docker:build": "docker build -t foma-render-engine .",
    "docker:run": "docker-compose up"
  },
  "devDependencies": {
    "@types/mjml": "^4.7.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "juice": "^11.0.1",
    "mjml": "^4.18.0"
  }
}
